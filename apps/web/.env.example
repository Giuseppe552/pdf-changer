VITE_API_BASE_URL=http://localhost:8788

# Optional: entitlement verification (P-256 ECDSA JWK public key as JSON string).
# VITE_ENTITLEMENT_PUBLIC_JWK={"kty":"EC","crv":"P-256","x":"...","y":"..."}

# Optional: donation links (Stripe hosted links/checkouts).
