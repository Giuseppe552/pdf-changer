# VITE_DONATE_STRIPE_MONTHLY_URL=https://buy.stripe.com/...

# Optional fallback only: used if manifest is missing on /donate/proof.
# VITE_DONATE_PGP_FINGERPRINT=ABCD1234EF567890ABCD1234EF567890ABCD1234
